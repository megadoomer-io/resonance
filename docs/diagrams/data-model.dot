// Core Data Model
// Music, taste, playlist, and task tables. Crow's-foot notation: tail "exactly
// one" (||), head "zero or many" (o{). Field-level detail lives in the tables
// in architecture.md; this shows the relationships between entities.
//
// Render: dot -Tsvg data-model.dot -o data-model.svg

digraph data_model {
    rankdir=LR;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", fillcolor="#f5f5f5"];
    edge [fontname="Helvetica", fontsize=8, color="#666666", dir=both, arrowtail=teetee, arrowhead=crowodot];

    users -> service_connections   [label="has"];
    users -> listening_events      [label="logs"];
    users -> user_artist_relations [label="follows"];
    users -> user_track_relations  [label="rates"];
    users -> playlists             [label="owns"];
    users -> generator_profiles    [label="owns"];
    users -> sync_tasks            [label="runs"];
    artists -> tracks              [label="by"];
    artists -> artist_tags         [label="tagged with"];
    artists -> artist_similarities [label="similar to"];
    tracks -> listening_events     [label="played in"];
    tracks -> playlist_tracks      [label="appears in"];
    artists -> user_artist_relations [label="target of"];
    tracks  -> user_track_relations  [label="target of"];
    service_connections -> user_artist_relations [label="sourced from"];
    service_connections -> user_track_relations  [label="sourced from"];
    service_connections -> sync_tasks            [label="scoped to"];
    playlists -> playlist_tracks   [label="contains"];
    generator_profiles -> generation_records [label="produces"];
    playlists -> generation_records [label="result of"];
    sync_tasks -> sync_tasks        [label="parent of"];
}
