// Cross-service entity resolution — concert/venue/event candidate tables
// resolved into canonical entities.
// Crow's-foot notation: tail "exactly one" (||), head "zero or many" (o{).
// Render: make diagrams  (dot -Tsvg)
digraph entity_resolution {
    rankdir=LR;
    graph [fontname="Helvetica", fontsize=11, nodesep=0.45, ranksep=0.9];
    node  [fontname="Helvetica", fontsize=10, shape=box, style="rounded,filled", fillcolor="#eef2ff", color="#3730a3"];
    edge  [fontname="Helvetica", fontsize=8, color="#475569", dir=both, arrowtail=teetee, arrowhead=crowodot];

    venues -> events                  [label="hosts"];
    venues -> venue_candidates        [label="resolved from"];
    events -> event_artists           [label="lineup"];
    events -> event_artist_candidates [label="raw lineup"];
    events -> event_candidates        [label="resolved from"];
    events -> user_event_attendance   [label="attended"];
    artists -> event_artists          [label="performs at"];
    artists -> event_artist_candidates [label="matched to"];
    venue_candidates -> event_candidates [label="venue of"];
    users -> user_event_attendance    [label="attends"];
}
