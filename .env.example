# Resonance environment variables
# Copy to .env and fill in your values.

# --- Database (PostgreSQL) ---
PGHOST=localhost
PGPORT=5432
PGUSER=resonance
PGPASSWORD=resonance
PGDATABASE=resonance

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Security (CHANGE THESE in any non-throwaway environment) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET_KEY=change-me-in-production
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=change-me-in-production

# --- Application ---
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# --- Worker ---
# "external" (prod, requires arq worker) or "inline" (dev, runs in web process)
WORKER_MODE=inline

# --- Spotify OAuth ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- MusicBrainz / ListenBrainz OAuth ---
MUSICBRAINZ_CLIENT_ID=
MUSICBRAINZ_CLIENT_SECRET=

# --- Last.fm API ---
LASTFM_API_KEY=
LASTFM_SHARED_SECRET=

# --- GitHub login (via Dex OIDC broker) ---
# Optional. When empty, GitHub login is disabled.
DEX_CLIENT_ID=
DEX_CLIENT_SECRET=
DEX_ISSUER_URL=

# --- Admin API ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_TOKEN=
